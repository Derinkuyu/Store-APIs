## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
*.pidb
*.resources
*.csproj.user
*.csproj.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Log]s/
[Tt]est[Rr]esults/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# File system tracking data
VisualStudio.nofiletrack

# All other temp/cache directories
[Tt]emp/

# MSTest test Results
[Te]st[Ou]tput/

# NUnit
/*.VisualState.xml
/*.suo

# OpenCover
pdf/

# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Live Unit Testing
.lut/

# Backup and restore files created by Visual Studio
*Backup*/

# Tooling
_ReSharper*/
*.[Re]Sharper.user
*.DotSettings.user

# Paket CLI
.paket/

# FAKE build system
.fake/

# JetBrains Rider
.idea/

# Local appsettings overrides (keep appsettings.json, but ignore user/dev specific environments if desired)
# appsettings.Development.json
# UserSecrets
secrets.json

# OS files
Thumbs.db
ehthumbs.db
.DS_Store

# EF Core Migrations
[Mm]igrations/
